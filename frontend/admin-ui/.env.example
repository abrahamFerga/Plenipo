# Copy to .env.local to override. Base URL of the Plenipo API the admin console reads from.
# Defaults to http://localhost:8080 (the GETTING_STARTED quickstart port). Point at the Aspire
# dashboard's plenipo-sample URL if you run via the AppHost.
VITE_API_BASE=http://localhost:8080

# Where the "← Workspace" link points. Defaults to "/" (correct when the domain UI is served same-origin).
# For the two-dev-server quickstart, point it at the domain UI's dev server so the link crosses over:
# VITE_WORKSPACE_URL=http://localhost:5173
