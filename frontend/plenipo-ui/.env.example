# Copy to .env.local to override. Base URL of the Plenipo API.
# Defaults to http://localhost:8080 (the GETTING_STARTED quickstart port).
# Point this at the Aspire dashboard's plenipo-sample URL if you run via the AppHost.
VITE_API_BASE=http://localhost:8080

# Where the "Admin ↗" link points. Defaults to "/admin" (correct when the API serves the admin console
# same-origin via UsePlenipoAdminConsole). For the two-dev-server quickstart, point it at the admin-ui
# dev server so the link actually crosses over:
# VITE_ADMIN_URL=http://localhost:5174/admin
