{
  "name": "@plenipo/ui",
  "version": "0.1.0-alpha",
  "description": "Base platform UI for Plenipo \u2014 chat shell, module switcher, server-driven tabs.",
  "license": "MIT",
  "homepage": "https://github.com/abrahamFerga/Plenipo/tree/main/frontend/plenipo-ui#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/abrahamFerga/Plenipo.git",
    "directory": "frontend/plenipo-ui"
  },
  "bugs": "https://github.com/abrahamFerga/Plenipo/issues",
  "type": "module",
  "main": "./dist/plenipo-ui.umd.js",
  "module": "./dist/plenipo-ui.es.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/plenipo-ui.es.js",
      "require": "./dist/plenipo-ui.umd.js"
    },
    "./tailwind-preset": "./tailwind-preset.js",
    "./theme.css": "./theme.css"
  },
  "files": [
    "dist",
    "tailwind-preset.js",
    "theme.css"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "peerDependencies": {
    "@microsoft/signalr": ">=8",
    "@tanstack/react-query": ">=5",
    "react": ">=18",
    "react-dom": ">=18",
    "react-router-dom": ">=6"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build && tsc -p tsconfig.build.json",
    "lint": "eslint .",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "preview": "vite preview",
    "prepack": "npm run build",
    "build:app": "tsc -b && vite build --mode app"
  },
  "dependencies": {
    "@microsoft/signalr": "^8.0.7",
    "@tanstack/react-query": "^5.101.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.0.1",
    "react-router-dom": "^6.27.0",
    "remark-gfm": "^4.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.13.0",
    "@playwright/test": "1.61.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.5.4",
    "eslint": "^9.13.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.20",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.65.0",
    "vite": "^6.4.3",
    "vitest": "^3.2.6"
  }
}
