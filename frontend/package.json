{
  "name": "@plenipo/frontend",
  "version": "0.1.0-alpha",
  "private": true,
  "description": "Plenipo UI monorepo — base platform library and domain-specific UI packages.",
  "packageManager": "pnpm@11.9.0",
  "scripts": {
    "dev": "pnpm --filter @plenipo/ui dev",
    "dev:admin": "pnpm --filter @plenipo/admin-ui dev",
    "build": "pnpm --filter @plenipo/ui build",
    "build:admin": "pnpm --filter @plenipo/admin-ui build",
    "build:all": "pnpm --filter @plenipo/ui build && pnpm --filter @plenipo/admin-ui build",
    "lint": "pnpm -r lint"
  }
}
