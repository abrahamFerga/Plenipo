{
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.AspNetCore": "Information"
    }
  },

  // Local-dev connection strings — point at the docker-compose Postgres (see GETTING_STARTED.md).
  // Platform and audit share one database via distinct schemas for simple local dev; production uses
  // separate databases (see infra/). When run via the Aspire AppHost these are overridden automatically.
  // Redis is intentionally omitted: single-instance dev uses in-memory SignalR. Set "cortex-redis":
  // "localhost:6379" to exercise the Redis backplane (docker-compose provides it).
  "ConnectionStrings": {
    "cortex-platform": "Host=localhost;Port=5432;Database=cortex_legal;Username=postgres;Password=postgres",
    "cortex-audit": "Host=localhost;Port=5432;Database=cortex_legal;Username=postgres;Password=postgres"
  },

  // The chatbot works out of the box with the dependency-free "Mock" provider.
  // To use a real model instead, set Provider + the matching fields below
  // (keep the key in user-secrets, never in this file):
  //
  //   OpenAI:      "Provider": "OpenAI",      "Model": "gpt-4o-mini",  "ApiKey": "<via user-secrets>"
  //   AzureOpenAI: "Provider": "AzureOpenAI", "Model": "<deployment>", "Endpoint": "https://<res>.openai.azure.com/"
  //   Ollama:      "Provider": "Ollama",      "Model": "llama3.1",     "Endpoint": "http://localhost:11434/v1"
  //
  //   dotnet user-secrets --project samples/Cortex.Sample.Host set "Ai:ApiKey" "sk-..."
  "Ai": {
    "Provider": "Mock"
  },

  // Opt-in RAG pipeline (index_matter_documents / search_knowledge). The "Mock" embedding provider
  // is deterministic and keyless, mirroring the Mock chat provider; for real retrieval quality set
  // "EmbeddingProvider": "OpenAI" + "EmbeddingModel": "text-embedding-3-small" (key via user-secrets,
  // falls back to Ai:ApiKey). Requires pgvector — the AppHost and docker-compose images provide it.
  "Rag": {
    "Enabled": true,
    "EmbeddingProvider": "Mock"
  }
}
