<Project Sdk="Aspire.AppHost.Sdk/13.4.6">

  <!--
    Aspire orchestration for the SAMPLE application (Plenipo.Sample.Host plus both
    domain modules). The one-command way to run the full Plenipo stack locally:
    Postgres (platform and audit DBs), Redis, and the API, with the chat assistant
    enabled via the dependency-free "Mock" provider. See AppHost.cs for the run command.
  -->
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <IsAspireHost>true</IsAspireHost>
    <UserSecretsId>plenipo-sample-apphost</UserSecretsId>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Aspire.Hosting.PostgreSQL" />
    <PackageReference Include="Aspire.Hosting.Redis" />
    <PackageReference Include="Aspire.Hosting.JavaScript" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Plenipo.Sample.Host\Plenipo.Sample.Host.csproj" />
  </ItemGroup>

</Project>
